# Environment Configuration
# Copy this file to .env and fill in your actual values

# Published Agent Application Endpoint
# After publishing your agent in the Foundry portal, construct the endpoint URL:
# https://<foundry-resource-name>.services.ai.azure.com/api/projects/<project-name>/applications/<app-name>/protocols/openai
AGENT_APP_ENDPOINT=your_agent_app_endpoint_here
